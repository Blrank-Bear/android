<?xml version="1.0" encoding="utf-8"?>
<!-- Simple X/O icon representing Tic Tac Toe -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- X mark -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M20,20 L44,44 M44,20 L20,44"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6"
        android:strokeLineCap="round" />

    <!-- O mark -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M72,32 m-14,0 a14,14 0 1,0 28,0 a14,14 0 1,0 -28,0"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6" />

    <!-- Grid lines -->
    <path
        android:pathData="M36,60 L36,100 M72,60 L72,100 M18,72 L90,72 M18,88 L90,88"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round" />
</vector>
